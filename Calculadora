<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Calculadora de Projetos</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f3; color: #1a1a1a; min-height: 100vh; padding: 2rem 1rem; }
  .container { max-width: 680px; margin: 0 auto; }
  h1 { font-size: 22px; font-weight: 500; margin-bottom: 4px; }
  .sub { font-size: 13px; color: #666; margin-bottom: 1.5rem; }
  .card { background: #fff; border: 1px solid #e5e5e5; border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; }
  .card-title { font-size: 11px; font-weight: 500; color: #888; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 14px; }
  .grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 10px; }
  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
  label { font-size: 12px; color: #666; display: block; margin-bottom: 4px; }
  input[type=text], input[type=number] { width: 100%; padding: 9px 11px; font-size: 14px; border: 1px solid #ddd; border-radius: 8px; background: #fafafa; color: #1a1a1a; font-family: inherit; outline: none; transition: border-color 0.15s, box-shadow 0.15s; }
  input:focus { border-color: #999; box-shadow: 0 0 0 3px rgba(0,0,0,0.06); }
  .date-label { font-size: 12px; color: #666; margin-bottom: 6px; display: block; }
  .date-toggle { display: flex; gap: 8px; margin-bottom: 10px; }
  .date-btn { flex: 1; padding: 9px; font-size: 13px; font-weight: 500; border: 2px solid #ddd; border-radius: 8px; background: #f5f5f3; color: #888; cursor: pointer; font-family: inherit; transition: all 0.15s; }
  .date-btn-16.selected { background: #185FA5; border-color: #0C447C; color: #fff; }
  .date-btn-25.selected { background: #BA7517; border-color: #854F0B; color: #fff; }
  .subtotal-preview { display: flex; align-items: center; justify-content: space-between; background: #f5f5f3; border-radius: 8px; padding: 10px 14px; margin-top: 8px; }
  .subtotal-preview span { font-size: 12px; color: #666; }
  .subtotal-preview strong { font-size: 16px; font-weight: 500; }
  .btn-add { width: 100%; padding: 10px; font-size: 14px; font-weight: 500; background: #fff; border: 1px solid #ddd; border-radius: 8px; color: #1a1a1a; cursor: pointer; font-family: inherit; margin-top: 10px; transition: background 0.15s; }
  .btn-add:hover { background: #f5f5f3; }
  .divider { height: 1px; background: #eee; margin: 1.25rem 0; }
  .project-item { background: #fff; border: 1px solid #e5e5e5; border-radius: 10px; padding: 0.9rem 1.1rem; margin-bottom: 6px; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .project-name { font-size: 13px; font-weight: 500; color: #1a1a1a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .project-meta { font-size: 11px; color: #888; margin-top: 2px; }
  .badge { display: inline-block; font-size: 10px; font-weight: 500; padding: 2px 7px; border-radius: 99px; margin-left: 6px; vertical-align: middle; }
  .badge-16 { background: #185FA5; color: #fff; }
  .badge-25 { background: #BA7517; color: #fff; }
  .project-value { font-size: 13px; font-weight: 500; white-space: nowrap; }
  .btn-del { background: none; border: none; cursor: pointer; font-size: 14px; color: #bbb; padding: 0 0 0 6px; line-height: 1; }
  .btn-del:hover { color: #e24b4a; }
  .results-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
  .pay-column { border-radius: 10px; overflow: hidden; border: 1px solid #e5e5e5; }
  .pay-header { padding: 10px 14px; display: flex; align-items: center; justify-content: space-between; }
  .pay-header-16 { background: #185FA5; }
  .pay-header-25 { background: #BA7517; }
  .pay-day, .pay-total { font-size: 13px; font-weight: 500; color: #fff; }
  .pay-total { font-size: 15px; }
  .pay-items { padding: 8px 0; background: #fff; }
  .pay-item { padding: 7px 14px; display: flex; justify-content: space-between; align-items: center; gap: 8px; border-bottom: 1px solid #f0f0f0; }
  .pay-item:last-child { border-bottom: none; }
  .pay-item-name { font-size: 12px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 110px; }
  .pay-item-val { font-size: 12px; color: #666; white-space: nowrap; }
  .pay-empty { padding: 16px 14px; font-size: 12px; color: #bbb; text-align: center; background: #fff; }
  .total-bar { background: #f5f5f3; border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .total-bar-label { font-size: 13px; color: #666; }
  .total-bar-val { font-size: 20px; font-weight: 500; }
  .delta-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
  .delta-box { border-radius: 8px; padding: 11px 14px; }
  .delta-box.neutral { background: #f5f5f3; }
  .delta-box.positive { background: #eaf3de; }
  .delta-box.negative { background: #fcebeb; }
  .delta-label { font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 3px; }
  .delta-box.neutral .delta-label, .delta-box.neutral .delta-val, .delta-box.neutral .delta-sub { color: #888; }
  .delta-box.positive .delta-label, .delta-box.positive .delta-val, .delta-box.positive .delta-sub { color: #3b6d11; }
  .delta-box.negative .delta-label, .delta-box.negative .delta-val, .delta-box.negative .delta-sub { color: #a32d2d; }
  .delta-val { font-size: 16px; font-weight: 500; }
  .delta-sub { font-size: 11px; margin-top: 2px; }
  .progress-wrap { margin-top: 12px; }
  .progress-bar-bg { height: 6px; background: #e5e5e5; border-radius: 99px; overflow: hidden; }
  .progress-bar-fill { height: 100%; border-radius: 99px; transition: width 0.3s; background: #888; }
  .progress-label { display: flex; justify-content: space-between; font-size: 11px; color: #888; margin-top: 4px; }
  .btn-export { width: 100%; padding: 10px; font-size: 13px; background: none; border: 1px solid #e5e5e5; border-radius: 8px; color: #888; cursor: pointer; font-family: inherit; margin-top: 8px; }
  .btn-export:hover { background: #f5f5f3; }
  @media (max-width: 480px) {
    .grid3 { grid-template-columns: 1fr 1fr; }
    .delta-row { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>
<div class="container">
  <h1>Calculadora de projetos</h1>
  <p class="sub">Adicione seus trabalhos e acompanhe sua meta</p>

  <div class="card">
    <div class="card-title">Novo projeto</div>
    <div style="margin-bottom:10px">
      <label>Descrição do trabalho</label>
      <input type="text" id="desc" placeholder="Ex: Desenvolvimento site XYZ" />
    </div>
    <div class="grid3">
      <div><label>Taxa / hora (R$)</label><input type="number" id="taxa" placeholder="150" min="0" step="0.01" oninput="updatePreview()" /></div>
      <div><label>Horas por dia</label><input type="number" id="horas" placeholder="8" min="0" step="0.5" oninput="updatePreview()" /></div>
      <div><label>Dias úteis</label><input type="number" id="dias" placeholder="22" min="0" step="1" oninput="updatePreview()" /></div>
    </div>
    <span class="date-label">Data de pagamento</span>
    <div class="date-toggle">
      <button class="date-btn date-btn-16 selected" id="btn-16" onclick="selectDate(16)">Dia 16</button>
      <button class="date-btn date-btn-25" id="btn-25" onclick="selectDate(25)">Dia 25</button>
    </div>
    <div class="subtotal-preview">
      <span>Subtotal estimado</span>
      <strong id="preview">R$ 0,00</strong>
    </div>
    <button class="btn-add" onclick="addProject()">+ Adicionar projeto</button>
  </div>

  <div id="section-results" style="display:none">
    <div class="divider"></div>
    <div id="all-projects" style="margin-bottom:1rem"></div>
    <div class="results-grid">
      <div class="pay-column">
        <div class="pay-header pay-header-16">
          <span class="pay-day">Dia 16</span>
          <span class="pay-total" id="col-total-16">R$ 0,00</span>
        </div>
        <div class="pay-items" id="col-items-16"><div class="pay-empty">Nenhum projeto</div></div>
      </div>
      <div class="pay-column">
        <div class="pay-header pay-header-25">
          <span class="pay-day">Dia 25</span>
          <span class="pay-total" id="col-total-25">R$ 0,00</span>
        </div>
        <div class="pay-items" id="col-items-25"><div class="pay-empty">Nenhum projeto</div></div>
      </div>
    </div>
    <div class="total-bar">
      <span class="total-bar-label">Total a receber</span>
      <span class="total-bar-val" id="total-geral">R$ 0,00</span>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Meta e hora extra</div>
    <div class="grid2">
      <div><label>Meta (R$)</label><input type="number" id="meta" placeholder="40000" min="0" step="100" oninput="updateGoal()" /></div>
      <div><label>Taxa hora extra (R$)</label><input type="number" id="taxa-extra" placeholder="160" min="0" step="0.01" oninput="updateGoal()" /></div>
    </div>
    <div class="delta-row" id="delta-row" style="display:none">
      <div class="delta-box neutral"><div class="delta-label">Meta</div><div class="delta-val" id="val-meta">—</div></div>
      <div class="delta-box neutral" id="box-delta"><div class="delta-label">Delta</div><div class="delta-val" id="val-delta">—</div><div class="delta-sub" id="sub-delta">—</div></div>
      <div class="delta-box neutral" id="box-extra"><div class="delta-label">Horas extras</div><div class="delta-val" id="val-extra">—</div><div class="delta-sub" id="sub-extra">—</div></div>
    </div>
    <div class="progress-wrap" id="progress-wrap" style="display:none">
      <div class="progress-bar-bg"><div class="progress-bar-fill" id="progress-fill" style="width:0%"></div></div>
      <div class="progress-label"><span id="progress-pct">0%</span><span id="progress-rest"></span></div>
    </div>
  </div>

<button class="btn-export" id="btn-export" style="display:none" onclick="exportText()">Exportar resumo como texto</button>

</div>

<script>
let projects = [];
let selectedDate = 16;

function fmt(v) { return v.toLocaleString('pt-BR',{style:'currency',currency:'BRL'}); }
function calcSub(t,h,d) { return (parseFloat(t)||0)*(parseFloat(h)||0)*(parseFloat(d)||0); }
function getTotal() { return projects.reduce((a,p)=>a+p.sub,0); }

function selectDate(d) {
  selectedDate = d;
  document.getElementById('btn-16').className = 'date-btn date-btn-16' + (d===16?' selected':'');
  document.getElementById('btn-25').className = 'date-btn date-btn-25' + (d===25?' selected':'');
}

function updatePreview() {
  document.getElementById('preview').textContent = fmt(calcSub(
    document.getElementById('taxa').value,
    document.getElementById('horas').value,
    document.getElementById('dias').value
  ));
}

function addProject() {
  const desc = document.getElementById('desc').value.trim();
  const taxa = parseFloat(document.getElementById('taxa').value)||0;
  const horas = parseFloat(document.getElementById('horas').value)||0;
  const dias = parseInt(document.getElementById('dias').value)||0;
  if (!desc) { document.getElementById('desc').focus(); return; }
  if (!taxa||!horas||!dias) return;
  projects.push({id:Date.now(),desc,taxa,horas,dias,sub:calcSub(taxa,horas,dias),date:selectedDate});
  render();
  ['desc','taxa','horas','dias'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('preview').textContent='R$ 0,00';
  document.getElementById('desc').focus();
}

function removeProject(id) { projects=projects.filter(p=>p.id!==id); render(); }

function render() {
  const show = projects.length > 0;
  document.getElementById('section-results').style.display = show?'block':'none';
  document.getElementById('btn-export').style.display = show?'block':'none';
  if (!show) { updateGoal(); return; }

  document.getElementById('all-projects').innerHTML = projects.map(p => {
    const th = (p.horas*p.dias).toLocaleString('pt-BR',{maximumFractionDigits:1});
    return `<div class="project-item">
      <div style="flex:1;min-width:0">
        <div class="project-name">${p.desc}<span class="badge badge-${p.date}">dia ${p.date}</span></div>
        <div class="project-meta">R$ ${p.taxa.toLocaleString('pt-BR',{minimumFractionDigits:2})}/h · ${p.horas}h/dia · ${p.dias} dias · ${th}h</div>
      </div>
      <div style="display:flex;align-items:center;gap:4px">
        <span class="project-value">${fmt(p.sub)}</span>
        <button class="btn-del" onclick="removeProject(${p.id})">✕</button>
      </div>
    </div>`;
  }).join('');

  const p16=projects.filter(p=>p.date===16), p25=projects.filter(p=>p.date===25);
  document.getElementById('col-total-16').textContent=fmt(p16.reduce((a,p)=>a+p.sub,0));
  document.getElementById('col-total-25').textContent=fmt(p25.reduce((a,p)=>a+p.sub,0));
  document.getElementById('col-items-16').innerHTML=p16.length
    ?p16.map(p=>`<div class="pay-item"><span class="pay-item-name">${p.desc}</span><span class="pay-item-val">${fmt(p.sub)}</span></div>`).join('')
    :'<div class="pay-empty">Nenhum projeto</div>';
  document.getElementById('col-items-25').innerHTML=p25.length
    ?p25.map(p=>`<div class="pay-item"><span class="pay-item-name">${p.desc}</span><span class="pay-item-val">${fmt(p.sub)}</span></div>`).join('')
    :'<div class="pay-empty">Nenhum projeto</div>';
  document.getElementById('total-geral').textContent=fmt(getTotal());
  updateGoal();
}

function updateGoal() {
  const meta=parseFloat(document.getElementById('meta').value)||0;
  const taxaExtra=parseFloat(document.getElementById('taxa-extra').value)||0;
  const total=getTotal();
  if (!meta) {
    document.getElementById('delta-row').style.display='none';
    document.getElementById('progress-wrap').style.display='none';
    return;
  }
  document.getElementById('delta-row').style.display='grid';
  document.getElementById('progress-wrap').style.display='block';
  const delta=meta-total, atingiu=delta<=0;
  document.getElementById('val-meta').textContent=fmt(meta);
  document.getElementById('box-delta').className='delta-box '+(atingiu?'positive':'negative');
  document.getElementById('val-delta').textContent=fmt(Math.abs(delta));
  document.getElementById('sub-delta').textContent=atingiu?'acima da meta':'faltando';
  const bx=document.getElementById('box-extra');
  if (!atingiu&&taxaExtra>0) {
    bx.className='delta-box negative';
    document.getElementById('val-extra').textContent=(delta/taxaExtra).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2})+'h';
    document.getElementById('sub-extra').textContent='a R$ '+taxaExtra.toLocaleString('pt-BR',{minimumFractionDigits:2})+'/h';
  } else if (atingiu) {
    bx.className='delta-box positive';
    document.getElementById('val-extra').textContent='Meta atingida';
    document.getElementById('sub-extra').textContent='';
  } else {
    bx.className='delta-box neutral';
    document.getElementById('val-extra').textContent='—';
    document.getElementById('sub-extra').textContent='informe taxa extra';
  }
  const pct=Math.min(100,total/meta*100);
  const fill=document.getElementById('progress-fill');
  fill.style.width=pct.toFixed(1)+'%';
  fill.style.background=atingiu?'#3b6d11':(pct>=75?'#BA7517':'#888');
  document.getElementById('progress-pct').textContent=pct.toFixed(1)+'%';
  document.getElementById('progress-rest').textContent=atingiu?'Meta batida!':fmt(total)+' de '+fmt(meta);
}

function exportText() {
  const meta=parseFloat(document.getElementById('meta').value)||0;
  const taxaExtra=parseFloat(document.getElementById('taxa-extra').value)||0;
  const total=getTotal();
  const p16=projects.filter(p=>p.date===16), p25=projects.filter(p=>p.date===25);
  let txt='RESUMO DE PROJETOS\n'+'='.repeat(34)+'\n\n';
  txt+='PAGAMENTO DIA 16\n';
  p16.length?p16.forEach(p=>{txt+=`  · ${p.desc}: ${fmt(p.sub)}\n`}):(txt+='  Nenhum projeto\n');
  txt+=`  Total dia 16: ${fmt(p16.reduce((a,p)=>a+p.sub,0))}\n\n`;
  txt+='PAGAMENTO DIA 25\n';
  p25.length?p25.forEach(p=>{txt+=`  · ${p.desc}: ${fmt(p.sub)}\n`}):(txt+='  Nenhum projeto\n');
  txt+=`  Total dia 25: ${fmt(p25.reduce((a,p)=>a+p.sub,0))}\n\n`;
  txt+='='.repeat(34)+'\nTOTAL A RECEBER: '+fmt(total)+'\n';
  if (meta) {
    const d=meta-total;
    txt+=`\nMETA: ${fmt(meta)}\nDelta: ${d>0?'-'+fmt(d)+' (faltando)':'+'+fmt(Math.abs(d))+' (acima da meta)'}\n`;
    if(d>0&&taxaExtra>0) txt+=`Horas extras: ${(d/taxaExtra).toFixed(2).replace('.',',')}h @ R$ ${taxaExtra.toFixed(2).replace('.',',')} /h\n`;
  }
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([txt],{type:'text/plain'}));
  a.download='resumo-projetos.txt';
  a.click();
}
</script>

</body>
</html>
